# Production Environment Variables for Docker
# These are automatically set by docker-compose.yml
NODE_ENV=production
PORT=5000
DB_HOST=db
DB_PORT=5432
DB_NAME=coreinventory
DB_USER=postgres
DB_PASSWORD=password123
JWT_SECRET=core_inventory_secret_key_2026
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=core_inventory_refresh_secret_2026
JWT_REFRESH_EXPIRES_IN=30d
CLIENT_URL=http://localhost:5173

# Email Configuration (Update for production)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=user_id
SMTP_PASS=password
EMAIL_FROM=noreply@coreinventory.com

# OTP Settings
OTP_EXPIRES_MINUTES=10
